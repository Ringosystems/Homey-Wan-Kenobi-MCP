{
  "name": "homey-mcp",
  "version": "2.1.1",
  "description": "MCP server for Homey Pro smart home control",
  "type": "module",
  "author": "Steeves and Associates",
  "license": "MIT",
  "homepage": "https://github.com/Ringosystems/Homey-Wan-Kenobi-MCP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ringosystems/Homey-Wan-Kenobi-MCP.git"
  },
  "bugs": {
    "url": "https://github.com/Ringosystems/Homey-Wan-Kenobi-MCP/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "homey-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "keywords": [
    "mcp",
    "homey",
    "smart-home",
    "home-automation",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "homey-api": "^3.19.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
